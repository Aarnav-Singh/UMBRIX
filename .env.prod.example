# .env.prod.example — Production environment variables for UMBRIX
# Copy this to .env.prod and fill in real values before deploying.
# NEVER commit .env.prod to version control.

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_STRONG_RANDOM_HEX_64_CHARS
# Optional: second key for zero-downtime rotation (old key accepted during transition)
JWT_FALLBACK_SECRET_KEY=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
# DSN is constructed from POSTGRES_PASSWORD at runtime via docker-compose substitution.
# Directly override here if using an external managed database (RDS, Cloud SQL, etc.)
POSTGRES_DSN=postgresql+asyncpg://sentinel:CHANGE_ME_STRONG_POSTGRES_PASSWORD@pgbouncer:5432/sentinel_fabric

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis-master:6379/0

# ─── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse-node1
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=sentinel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME_CLICKHOUSE_PASSWORD

# ─── Grafana ──────────────────────────────────────────────────────────────────
GF_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["https://yourdomain.com"]

# ─── Threat Intel APIs (leave blank to disable) ──────────────────────────────
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
MISP_URL=
MISP_API_KEY=
TAXII_URL=
TAXII_COLLECTION_ID=
TAXII_TOKEN=

# ─── LLM / Narrative Engine ──────────────────────────────────────────────────
NARRATIVE_MODE=template
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLAMA_CPP_BASE_URL=http://localhost:8080/v1

# ─── SOAR Integrations ────────────────────────────────────────────────────────
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
PALOALTO_HOST=
PALOALTO_API_KEY=
OKTA_DOMAIN=
OKTA_API_TOKEN=
