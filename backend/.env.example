# Sentinel Fabric V2 — Backend Environment
# Copy to .env and replace placeholder values.

# ── App ──────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── Auth (self-issued JWT) ───────────────────────────
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ── ClickHouse ───────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=sentinel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel

# ── Kafka ────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=sentinel-pipeline

# ── Qdrant ───────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Pipeline ─────────────────────────────────────────
PIPELINE_BUDGET_MS=2000
SSE_HEARTBEAT_SECONDS=15

# ── IOC Feed Integration ─────────────────────────────
OTX_API_KEY=
IOC_FEED_INTERVAL_HOURS=6

# ── Narrative Generation ─────────────────────────────
NARRATIVE_MODE=template  # "llm" for Claude/OpenAI/llama.cpp, "template" for offline
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLAMA_CPP_BASE_URL=http://localhost:8080/v1
LLAMA_CPP_MODEL=deepseek-coder
LLAMA_CPP_TEMPERATURE=0.2
LLAMA_CPP_MAX_TOKENS=200

# ── SOAR Integrations ───────────────────────────────
# Leave blank to run in mock mode (actions are logged but not executed).

# CrowdStrike Falcon (OAuth2 client)
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com
CROWDSTRIKE_API_KEY=

# Palo Alto Networks PAN-OS
PALOALTO_HOST=
PALOALTO_API_KEY=

# Okta
OKTA_DOMAIN=
OKTA_API_TOKEN=
