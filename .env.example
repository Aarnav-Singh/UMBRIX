# ══════════════════════════════════════════════════════════════════════════
# Sentinel Fabric V2 — Environment Variables
# ══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and replace the placeholder values.
#
# ALL sensitive values MUST be set via environment variables.
# NEVER commit real secrets to version control.
# ══════════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]  # JSON array of allowed origins

# ── Authentication (REQUIRED) ───────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
INTERNAL_SERVICE_API_KEY=CHANGE-ME-IN-PRODUCTION # Separate from JWT secret for security (CRIT-01)
JWT_FALLBACK_SECRET_KEY=           # optional, for zero-downtime key rotation
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440             # 24 hours

# ── Ingest API Key (REQUIRED for production) ────────────
# All /api/v1/ingest/* endpoints require this key in the X-Ingest-API-Key header.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ⚠️  FAIL-CLOSED: If this value is empty or unset, ALL ingest endpoints
#    will return HTTP 503. This is by design — set it before testing ingest.
INGEST_API_KEY=

# ── MFA Enforcement ─────────────────────────────────────
# Roles that MUST have MFA enabled before login is allowed.
# Comma-separated: admin,analyst
REQUIRE_MFA_FOR_ROLES=["admin"]

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── ClickHouse ──────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=sentinel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_TTL_DAYS=90              # Data retention period in days

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Kafka ───────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=sentinel-pipeline

# ── Qdrant (Vector DB) ─────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── AI / LLM (Narrative Engine) ────────────────────────
NARRATIVE_MODE=llm                  # llm | template
LLM_BACKEND=anthropic               # anthropic | llama_cpp
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Threat Intelligence ────────────────────────────────
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
NVD_API_KEY=
SHODAN_API_KEY=

# ── SOAR Integrations ──────────────────────────────────
# CrowdStrike Falcon
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# Palo Alto PAN-OS
PALOALTO_HOST=
PALOALTO_API_KEY=

# Okta
OKTA_DOMAIN=                         # e.g. https://your-org.okta.com
OKTA_API_TOKEN=

# ServiceNow CMDB
SERVICENOW_INSTANCE=                 # e.g. https://your-org.service-now.com
SERVICENOW_USER=
SERVICENOW_PASSWORD=

# ── ChatOps / Notifications ───────────────────────────
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=                # required for Slack webhook auth
TEAMS_WEBHOOK_URL=
TEAMS_WEBHOOK_SECRET=                # required for Teams webhook HMAC auth

# ── Email / SMTP ───────────────────────────────────────
# Works with any SMTP provider (AWS SES, SendGrid, generic SMTP relay)
SMTP_HOST=                           # e.g. email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@sentinelfabric.io
SMTP_USE_TLS=true

# ── HashiCorp Vault (Optional) ─────────────────────────
# When configured, secrets are loaded from Vault at startup
# and refreshed every VAULT_ROTATION_INTERVAL seconds.
VAULT_URL=
VAULT_TOKEN=
VAULT_PATH=sentinel
VAULT_MOUNT_POINT=secret
VAULT_ROTATION_INTERVAL=900
